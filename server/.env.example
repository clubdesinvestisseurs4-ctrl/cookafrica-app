# Copier ce fichier en .env et remplir les valeurs

NODE_ENV=development
PORT=3001

# JWT – générer avec : openssl rand -base64 32
JWT_SECRET=changez_ce_secret_en_production

# Jeton requis pour appeler POST /api/auth/seed (création des comptes par défaut).
# Générer avec : openssl rand -base64 32 — à fournir via le header X-Seed-Token.
SEED_TOKEN=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=votre-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@votre-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# URL du frontend (Vercel)
CLIENT_URL=http://localhost:5500

# Restriction Wi-Fi : mettre WIFI_RESTRICTION_ENABLED=true pour activer
# ALLOWED_IPS : liste d'IPs autorisées séparées par des virgules
#   - IP exacte       : 203.0.113.42
#   - Plage CIDR      : 192.168.1.0/24
#   - Mixte           : 203.0.113.42,10.0.0.0/8
WIFI_RESTRICTION_ENABLED=false
ALLOWED_IPS=
